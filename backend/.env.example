# Copy this file to .env and fill in your values
# cp .env.example .env

# Cloudinary - Image upload service (https://cloudinary.com)
CLOUD_KEY = ""
CLOUD_NAME = ""
CLOUD_SECRET = ""

# JWT - Secret keys for authentication tokens
JWT_SECRET = ""
JWT_REFRESH_SECRET = ""

# MongoDB - Connection string (https://www.mongodb.com/atlas)
MONGO_URI = ""

# Server
PORT = 5000
NODE_ENV = "development"

# Frontend URL - Used for CORS and Stripe redirect URLs
# Development: http://localhost:5173
# Production: https://your-domain.com
FRONTEND_URL = "http://localhost:5173"

# Backend URL - Used for OAuth callback URLs and webhooks
# Development: http://localhost:5000
# Production: https://api.your-domain.com
BACKEND_URL = "http://localhost:5000"

# Stripe - Payment gateway (https://stripe.com)
STRIPE_SECRET_KEY = ""
STRIPE_WEBHOOK_SECRET = ""

# Email - Gmail SMTP via Nodemailer
# Use App Password (not your Gmail password): https://myaccount.google.com/apppasswords
SMTP_USER = ""
SMTP_PASS = ""

# Google OAuth 2.0 (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID = ""
GOOGLE_CLIENT_SECRET = ""

# Facebook OAuth (https://developers.facebook.com/apps)
FACEBOOK_APP_ID = ""
FACEBOOK_APP_SECRET = ""
